{
  // 文件作用：环轨设备参数文件。
  // 影响功能：影响串口/从站等设备连接参数。
  // 使用场景：LoopTrack 设备参数维护。
    // 环线配置。
  "LoopTrack": {
      // 雷玛连接配置。
      "LeiMaConnection": {
        // Modbus 串口 RTU 配置。
        "SerialRtu": {
          // 串口端口名称。
          "PortName": "COM4",
          // 串口波特率。
          "BaudRate": 38400,
          // 串口校验位（枚举全集：None、Odd、Even、Mark、Space）。
          "Parity": "None",
          // 串口数据位。
          "DataBits": 8,
          // 串口停止位（枚举全集：None、One、Two、OnePointFive）。
          "StopBits": "One"
        }
      }
    }
}
