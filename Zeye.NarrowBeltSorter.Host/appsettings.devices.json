              "DinChannel": 1,
              // 默认转向方向。
              "DefaultDirection": "Left",
              // 红外控制模式。
              "ControlMode": "Position",
              // 默认速度（毫米/秒）。
              "DefaultSpeedMmps": 800,
              // 默认位移（毫米）。
              "DefaultDistanceMm": 1200,
              // 保持时长（毫秒）。
              "HoldDurationMs": 50,
              // 触发延时（毫秒）。
              "TriggerDelayMs": 10,
              // 滚筒直径（毫米）。
              "RollerDiameterMm": 80,
              // 拨码编码。
              "DialCode": 1
            },
            // 格口编号 102 对应的映射项。
            "102": {
              // DIN 输入通道号。
              "DinChannel": 2,
              // 默认转向方向。
              "DefaultDirection": "Left",
              // 红外控制模式。
              "ControlMode": "Position",
              // 默认速度（毫米/秒）。
              "DefaultSpeedMmps": 800,
              // 默认位移（毫米）。
              "DefaultDistanceMm": 1200,
              // 保持时长（毫秒）。
              "HoldDurationMs": 50,
              // 触发延时（毫秒）。
              "TriggerDelayMs": 10,
              // 滚筒直径（毫米）。
              "RollerDiameterMm": 80,
              // 拨码编码。
              "DialCode": 1
            },
            // 格口编号 103 对应的映射项。
            "103": {
              // DIN 输入通道号。
              "DinChannel": 3,
              // 默认转向方向。
              "DefaultDirection": "Left",
              // 红外控制模式。
              "ControlMode": "Position",
              // 默认速度（毫米/秒）。
              "DefaultSpeedMmps": 800,
              // 默认位移（毫米）。
              "DefaultDistanceMm": 1200,
              // 保持时长（毫秒）。
              "HoldDurationMs": 50,
              // 触发延时（毫秒）。
              "TriggerDelayMs": 10,
              // 滚筒直径（毫米）。
              "RollerDiameterMm": 80,
              // 拨码编码。
              "DialCode": 1
            }
          }
        }
      ]
    },
    // 强排配置。
    "ForcedRotation": {
      // 强排格口序列。
      "ChuteSequence": []
    },
    // 包裹落格模拟轮询配置。
    "DropSimulation": {
      // 轮询格口序列（Mode=RoundRobin 时生效）。
      "ChuteSequence": []
    }
