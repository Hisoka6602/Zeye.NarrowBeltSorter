{
  // 环线配置。
  "LoopTrack": {
    // 雷玛连接配置。
    "LeiMaConnection": {
      // Modbus 串口 RTU 配置。
      "SerialRtu": {
        // 串口端口名称。
        "PortName": "COM1",
        // 串口波特率。
        "BaudRate": 38400,
        // 串口校验位。
        "Parity": "None",
        // 串口数据位。
        "DataBits": 8,
        // 串口停止位。
        "StopBits": "One"
      }
    }
  },
  // 格口驱动配置。
  "Chutes": {
    // 智嵌格口配置。
    "ZhiQian": {
      // 设备列表。
      "Devices": [
        {
          // 设备主机地址。
          "Host": "192.168.1.253",
          // 设备端口。
          "Port": 1030,
          // 设备地址。
          "DeviceAddress": 1,
          // 格口到 DO 路号映射。
          "ChuteToDoMap": {
            // 格口编号 101 对应的映射项。
            "101": 1,
            // 格口编号 102 对应的映射项。
            "102": 2,
            // 格口编号 103 对应的映射项。
            "103": 3
          },
          // 红外格口参数映射。
          "InfraredChuteOptionsMap": {
            // 格口编号 101 对应的映射项。
            "101": {
