{
  // 文件作用：全局基础配置文件（生产环境基线）。
  // 影响功能：影响日志清理、分拣时序与日志级别等跨模块能力。
  // 使用场景：全环境统一通用基线；无环境覆盖文件，所有环境使用同一参数。
  // 日志清理配置：控制日志目录保留与清理扫描策略。
  "LogCleanup": {
    // 是否启用日志清理后台服务（取值：true/false；仅服务启动时生效）。
    "Enabled": true,
    // 日志保留天数（单位：天，建议范围：1~365；支持热更新）。
    "RetentionDays": 2,
    // 清理检查间隔（单位：小时，建议范围：1~24；支持热更新，按新间隔进入下一轮等待）。
    "CheckIntervalHours": 1,
    // 日志目录路径（相对或绝对路径；支持热更新）。
    "LogDirectory": "logs"
  },
  // 分拣任务时序配置：控制包裹成熟延迟与格口开关门间隔。
  "SortingTask": {
    // 分拣任务时序参数。
    "Timing": {
      // 包裹从创建到进入待装车队列的成熟延迟（单位：毫秒，建议范围：100~60000）。
      "ParcelMatureDelayMs": 1175,
      // 包裹成熟时间起始来源（枚举全集：ParcelCreateSensor、LoadingTriggerSensor）。
      "ParcelMatureStartSource": "LoadingTriggerSensor",
      // 当起始来源为 LoadingTriggerSensor 且尚未接收到上车触发时，是否回退为创建包裹触发源（取值：true/false）。
      "EnableFallbackToParcelCreateWhenLoadingTriggerMissing": false,
      // 上车触发相对创建触发允许的最大滞后窗口（单位：毫秒，建议范围：1~30000；超过该窗口判定该包裹丢失并跳过上车）。
      "LoadingTriggerLagWindowMs": 2000,
      // 格口开门到关门的间隔时间（单位：毫秒，建议范围：50~5000）。
      "ChuteOpenCloseIntervalMs": 350,
      // 链路阶段耗时告警阈值（单位：毫秒，建议范围：500~30000）。任意链路阶段耗时超过此阈值时输出告警日志并附带上下文信息。
      "ParcelChainAlertThresholdMs": 3000,
      // 小车步距（单位：mm，取值范围：大于 0，建议范围：100~2000）。
      // 用于计算单步距时间 CarrierPeriodMs = CarrierPitchMm / RealtimeSpeedMmps * 1000，
      // 进而推导延迟占比 DelayRatio = EffectiveDelayMs / CarrierPeriodMs * 100%。
      // 填 0 时补偿计算门禁会降级为固定偏移（FallbackReason=InvalidCarrierPitchMm）。
      "CarrierPitchMm": 300,
      // 是否启用上车匹配时序补偿（取值：true/false；默认关闭；
      // 仅采集到足够 DelayRatio 样本并完成现场标定后方可置为 true）。
      "EnableLoadingMatchTimeCompensation": true,
      // 上车匹配补偿偏移量 delta（取值：整数；首版推荐填写 0 或 +1；
      // +1 表示顺时针偏移一车，0 表示不偏移。EnableLoadingMatchTimeCompensation=false 时忽略此字段）。
      "LoadingMatchCompensationDelta": 1,
      // 上车匹配补偿激活阈值（百分比，取值范围：0~100，须大于 LoadingMatchCompensationExitPercent；默认 95）。
      // DelayRatio 上穿此阈值时进入补偿态（与 Exit 联合形成滞回门限）。
      "LoadingMatchCompensationEnterPercent": 95,
      // 上车匹配补偿退出阈值（百分比，取值范围：0~100，须小于 LoadingMatchCompensationEnterPercent；默认 90）。
      // DelayRatio 下穿此阈值时退出补偿态（与 Enter 联合形成滞回门限）。
      "LoadingMatchCompensationExitPercent": 90,
      // 延迟占比平滑窗口大小（取值范围：1~20；1 表示关闭平滑，直接使用原始占比；默认 1）。
      // 同时配置滞回与平滑时：先对 DelayRatio 做平滑，再判定 Enter/Exit 门限。
      "LoadingMatchSmoothingWindowSize": 16,
      // 环线速度合法范围最小值（单位：mm/s，取值范围：大于 0 且小于 RealtimeSpeedValidMaxMmps；默认 100）。
      // 实时速度低于此值时补偿降级为固定偏移（FallbackReason=InvalidRealtimeSpeed）。
      "RealtimeSpeedValidMinMmps": 100,
      // 环线速度合法范围最大值（单位：mm/s，取值范围：大于 RealtimeSpeedValidMinMmps；默认 3000）。
      // 实时速度高于此值时补偿降级为固定偏移（FallbackReason=InvalidRealtimeSpeed）。
      "RealtimeSpeedValidMaxMmps": 3000
    }
  },
  // 框架日志级别配置：控制各命名空间日志输出级别。
  "Logging": {
    // 日志级别映射（取值示例：Trace/Debug/Information/Warning/Error/Critical/None）。
    "LogLevel": {
      // 默认日志级别。
      "Default": "Information",
      // Host 生命周期日志级别。
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
