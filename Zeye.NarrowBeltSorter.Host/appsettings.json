{
  // 日志清理配置：控制日志目录保留与清理扫描策略。
  "LogCleanup": {
    // 是否启用日志清理后台服务（取值：true/false）。
    "Enabled": true,
    // 日志保留天数（单位：天，建议范围：1~365）。
    "RetentionDays": 2,
    // 清理检查间隔（单位：小时，建议范围：1~24）。
    "CheckIntervalHours": 1,
    // 日志目录路径（相对或绝对路径）。
    "LogDirectory": "logs"
  },
  // 分拣任务时序配置：控制包裹成熟延迟与格口开关门间隔。
  "SortingTask": {
    // 分拣任务时序参数。
    "Timing": {
      // 包裹从创建到进入待装车队列的成熟延迟（单位：毫秒，建议范围：100~60000）。
      "ParcelMatureDelayMs": 2500,
      // 格口开门到关门的间隔时间（单位：毫秒，建议范围：50~5000）。
      "ChuteOpenCloseIntervalMs": 350
    }
  },
  // 框架日志级别配置：控制各命名空间日志输出级别。
  "Logging": {
    // 日志级别映射（取值示例：Trace/Debug/Information/Warning/Error/Critical/None）。
    "LogLevel": {
      // 默认日志级别。
      "Default": "Information",
      // Host 生命周期日志级别。
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
