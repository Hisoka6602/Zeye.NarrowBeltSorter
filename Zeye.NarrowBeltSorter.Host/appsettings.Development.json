{
  "LogCleanup": {
    "Enabled": true,
    "RetentionDays": 2,
    "CheckIntervalHours": 1,
    "LogDirectory": "logs"
  },
  "LoopTrack": {
    "Enabled": true,
    "TrackName": "LeiMa-Dev-LoopTrack",
    "AutoStart": true,
    "TargetSpeedMmps": 1200,
    "PollingIntervalMs": 300,
    "LeiMaConnection": {
      "RemoteHost": "127.0.0.1:502",
      "SlaveAddress": 1,
      "TimeoutMs": 1000,
      "RetryCount": 2,
      "MaxOutputHz": 50,
      "MaxTorqueRawUnit": 1000
    },
    "Pid": {
      "Kp": 1.0,
      "Ki": 0.0,
      "Kd": 0.0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
