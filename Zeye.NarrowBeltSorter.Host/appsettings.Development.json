{
  // 日志清理配置（Development 环境覆盖）：控制日志目录保留与清理扫描策略。
  "LogCleanup": {
    // 是否启用日志清理后台服务（取值：true/false）。
    "Enabled": true,
    // 日志保留天数（单位：天，建议范围：1~365）。
    "RetentionDays": 2,
    // 清理检查间隔（单位：小时，建议范围：1~24）。
    "CheckIntervalHours": 1,
    // 日志目录路径（相对或绝对路径）。
    "LogDirectory": "logs"
  },
  // 框架日志级别配置（Development 环境覆盖）：控制各命名空间日志输出级别。
  "Logging": {
    // 日志级别映射（取值示例：Trace/Debug/Information/Warning/Error/Critical/None）。
    "LogLevel": {
      // 默认日志级别。
      "Default": "Information",
      // Host 生命周期日志级别。
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
