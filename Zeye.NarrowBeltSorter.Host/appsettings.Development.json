{
  // 日志清理配置：控制日志目录保留与清理扫描策略。
  "LogCleanup": {
    // 是否启用日志清理后台服务（取值：true/false）。
    "Enabled": true,
    // 日志保留天数（单位：天，建议范围：1~365）。
    "RetentionDays": 2,
    // 清理检查间隔（单位：小时，建议范围：1~24）。
    "CheckIntervalHours": 1,
    // 日志目录路径（相对或绝对路径）。
    "LogDirectory": "logs"
  },
  // 环轨服务配置：控制 LeiMa 环轨连接、闭环稳速与运行日志。
  "LoopTrack": {
    // 是否启用环轨后台服务（取值：true/false）。
    "Enabled": true,
    // 轨道名称（用途：日志标识与运维定位）。
    "TrackName": "LeiMa-LoopTrack",
    // 是否在连接成功后自动启动轨道并自动设速（取值：true/false）。
    "AutoStart": true,
    // 自动启动设定目标速度（单位：mm/s，建议范围：0~2500）。
    "TargetSpeedMmps": 1500,
    // 服务轮询间隔（单位：毫秒，建议范围：50~5000）。
    "PollingIntervalMs": 300,
    // LeiMa 连接配置：通信方式、地址、超时、重试与输出约束。
    "LeiMaConnection": {
      // 传输模式（取值：TcpGateway 或 SerialRtu）。
      "Transport": "SerialRtu",
      // TCP 网关地址（格式：IP:Port；Transport=TcpGateway 时生效）。
      "RemoteHost": "127.0.0.1:502",
      // 串口 RTU 参数（Transport=SerialRtu 时生效）。
      "SerialRtu": {
        // 串口号（示例：COM1）。
        "PortName": "COM1",
        // 波特率（单位：bps，常见值：9600/19200/38400）。
        "BaudRate": 38400,
        // 校验位（取值：None/Odd/Even/Mark/Space）。
        "Parity": "None",
        // 数据位（单位：bit，取值范围：5~8）。
        "DataBits": 8,
        // 停止位（取值：One/Two/OnePointFive）。
        "StopBits": "One"
      },
      // Modbus 从站地址列表（每个元素取值范围：1~247，单从站请配置单元素数组）。
      "SlaveAddresses": [ 1, 2 ],
      // 多从站速度汇总策略（取值：Min/Avg/Median）。
      "SpeedAggregateStrategy": "Min",
      // 通信超时（单位：毫秒，建议范围：100~10000）。
      "TimeoutMs": 1000,
      // 通信重试次数（不含首次，建议范围：0~10）。
      "RetryCount": 2,
      // 最大输出频率（单位：Hz，建议范围：1~60）。
      "MaxOutputHz": 25,
      // P3.10 转矩给定最大原始值（单位：寄存器计数，建议范围：1~1000）。
      "MaxTorqueRawUnit": 1000,
      // P3.10 命令写入最小间隔（单位：毫秒，建议范围：50~5000）。
      "TorqueSetpointWriteIntervalMs": 300
    },
    // PID 参数：用于闭环稳速（反馈速度→PID→P3.10 输出）。
    "Pid": {
      // 是否启用 PID 闭环稳速（取值：true/false）。
      "Enabled": true,
      // 比例系数 Kp（建议范围：0~10）。
      // 现场稳健起步参数：Kp=0.28。
      "Kp": 0.28,
      // 积分系数 Ki（建议范围：0~10）。
      // 现场稳健起步参数：Ki=0.028。
      "Ki": 0.028,
      // 微分系数 Kd（建议范围：0~10）。
      // 现场稳健起步参数：Kd=0.005。
      "Kd": 0.005,
      // 输出下限（单位：Hz，建议范围：0~MaxOutputHz）。
      "OutputMinHz": 0.0,
      // 输出上限（单位：Hz，建议范围：OutputMinHz~MaxOutputHz）。
      "OutputMaxHz": 25.0,
      // 积分下限（单位：Hz 域积分量，建议范围：-100~0）。
      "IntegralMin": -10.0,
      // 积分上限（单位：Hz 域积分量，建议范围：0~100）。
      "IntegralMax": 10.0,
      // 微分滤波系数（取值范围：0~1，越大响应越快）。
      "DerivativeFilterAlpha": 0.2,
      // 非运行状态是否冻结积分（取值：true/false）。
      "FreezeIntegralWhenNotRunning": true
    },
    // 连接重试策略：连接失败时的退避重试控制。
    "ConnectRetry": {
      // 最大重试次数（不含首次，建议范围：0~20）。
      "MaxAttempts": 3,
      // 初始重试间隔（单位：毫秒，建议范围：100~10000）。
      "DelayMs": 1000,
      // 最大重试间隔（单位：毫秒，建议范围：DelayMs~60000）。
      "MaxDelayMs": 5000
    },
    // 运行日志配置：控制实时速度、调参与状态日志频率。
    "Logging": {
      // 是否输出详细状态调试日志（取值：true/false）。
      "EnableVerboseStatus": true,
      // 是否输出实时速度日志（目标/实时/偏差等，取值：true/false）。
      "EnableRealtimeSpeedLog": true,
      // 是否输出 PID 调参日志（P/I/D 分量、命令值、限幅状态，取值：true/false）。
      "EnablePidTuningLog": true,
      // Info 状态日志间隔（单位：毫秒，建议范围：200~10000）。
      "InfoStatusIntervalMs": 3000,
      // Debug 状态日志间隔（单位：毫秒，建议范围：100~10000）。
      "DebugStatusIntervalMs": 1000,
      // 实时速度日志间隔（单位：毫秒，建议范围：100~10000）。
      "RealtimeSpeedLogIntervalMs": 1000,
      // PID 调参日志间隔（单位：毫秒，建议范围：100~10000）。
      "PidTuningLogIntervalMs": 1000,
      // 轨道分类日志目录（相对或绝对路径）。
      "CategoryLogDirectory": "logs/looptrack",
      // 是否启用轨道分类文件日志（取值：true/false）。
      "EnableCategoryFile": true,
      // 分类文件保留天数（单位：天，建议范围：1~365）。
      "CategoryRetentionDays": 7,
      // 失稳偏差阈值（单位：mm/s，建议范围：0~1000）。
      "UnstableDeviationThresholdMmps": 100,
      // 失稳持续时长阈值（单位：毫秒，建议范围：100~60000）。
      "UnstableDurationMs": 3000
    },
    // 上机联调配置：用于现场联机调试流程与观测控制。
    "Hil": {
      // 是否启用上机联调后台服务（取值：true/false，默认关闭）。
      "Enabled": true,
      // 状态周期日志间隔（单位：毫秒，建议范围：100~10000）。
      "StatusLogIntervalMs": 1000,
      // 是否启用按键停轨（按 StopKey 配置按键停轨，非交互环境自动降级，取值：true/false）。
      "EnableKeyboardStop": true,
      // 键盘停轨轮询周期（单位：毫秒，建议范围：50~1000）。
      "KeyboardStopPollingIntervalMs": 200,
      // 键盘停轨按键（取值：ConsoleKey 枚举名称，如 S/Escape）。
      "StopKey": "Escape",
      // 服务启动后是否自动连接设备（取值：true/false）。
      "AutoConnectOnStart": true,
      // 连接成功后是否自动执行清报警（取值：true/false）。
      "AutoClearAlarmAfterConnect": true,
      // 连接成功后是否自动设置初始目标速度（取值：true/false）。
      "AutoSetInitialTargetAfterConnect": true,
      // 初始目标速度（单位：mm/s，建议范围：0~2500）。
      "InitialTargetSpeedMmps": 1500,
      // 连接成功后是否自动启动轨道（取值：true/false）。
      "AutoStartAfterConnect": true,
      // 连接失败最大重试次数（不含首次，建议范围：0~20）。
      "ConnectMaxAttempts": 3,
      // 连接失败重试间隔（单位：毫秒，建议范围：100~10000）。
      "ConnectRetryDelayMs": 1000,
      // 是否输出详细事件日志（取值：true/false）。
      "EnableVerboseEventLog": true
    }
  },
  // 框架日志级别配置：控制各命名空间日志输出级别。
  "Logging": {
    // 日志级别映射（取值示例：Trace/Debug/Information/Warning/Error/Critical/None）。
    "LogLevel": {
      // 默认日志级别。
      "Default": "Information",
      // Host 生命周期日志级别。
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
