    // EMC 连接配置。
    "EmcConnection": {
      // 是否启用 Leadshaine EMC 配置/功能（取值：true/false）。
      "Enabled": true,
      // EMC 建连超时（单位：毫秒，建议范围：100~60000）。
      "ConnectionTimeoutMs": 3000,
      // EMC 板卡编号（单位：无，建议范围：0~65535；默认 0 表示首块板卡）。
      "CardNo": 8,
      // EMC 错误码读取通道编号（单位：无，建议范围：0~65535；用于 nmc_get_errcode 通道参数）。
      "Channel": 0,
      // EMC 控制器 IP（空字符串表示本地板卡模式，非空时按以太网模式连接）。
      "ControllerIp": "192.168.5.11",
      // 初始化重试次数（不含首次，建议范围：0~20）。
      "InitializeRetryCount": 3,
      // 初始化重试初始间隔（单位：毫秒，建议范围：50~10000）。
      "InitializeRetryDelayMs": 2300,
      // IO 轮询间隔（单位：毫秒，建议范围：10~5000）。
      "PollingIntervalMs": 15,
      // 断链重连初始间隔（单位：毫秒，建议范围：50~10000）。
      "ReconnectBaseDelayMs": 200,
      // 断链重连最大间隔（单位：毫秒，建议范围：ReconnectBaseDelayMs~60000）。
      "ReconnectMaxDelayMs": 5000
    }
