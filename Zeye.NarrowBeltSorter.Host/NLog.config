<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">
	<extensions>
		<add assembly="NLog.Extensions.Logging" />
	</extensions>

	<variable name="loopTrackLogDir" value="${basedir}/${configsetting:item=LoopTrack\:Logging\:CategoryLogDirectory:default=logs/looptrack}" />
	<variable name="chuteLogDir" value="${basedir}/${configsetting:item=Chutes\:ZhiQian\:Logging\:CategoryLogDirectory:default=logs/chutes}" />
	<variable name="orchestrationLogDir" value="${basedir}/logs/orchestration" />
	<variable name="carrierLogDir" value="${basedir}/logs/carrier" />
	<variable name="emcLogDir" value="${basedir}/logs/emc" />
	<variable name="systemLogDir" value="${basedir}/logs/system" />

	<targets async="true">
		<target name="console" xsi:type="Console"
		        layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message}${onexception:inner= | ${exception:format=type,message:maxInnerExceptionLevel=1}}" />

		<target name="looptrack-status" xsi:type="File"
				fileName="${var:loopTrackLogDir}/looptrack-status/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

		<target name="looptrack-pid" xsi:type="File"
				fileName="${var:loopTrackLogDir}/looptrack-pid/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

		<target name="looptrack-modbus" xsi:type="File"
				fileName="${var:loopTrackLogDir}/looptrack-modbus/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<target name="looptrack-fault" xsi:type="File"
				fileName="${var:loopTrackLogDir}/looptrack-fault/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />
		<target name="looptrack-speed" xsi:type="File"
		        fileName="${var:loopTrackLogDir}/looptrack-speed/${shortdate}.log"
		        archiveEvery="Day"
		        maxArchiveDays="7"
		        layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

		<!-- 格口日志目标：chute-status（格口状态变更与连接日志）。
		     注意：maxArchiveDays 不支持 NLog Layout 渲染，故固定为 7；
		     如需修改保留天数，请直接调整此值。 -->
		<target name="chute-status" xsi:type="File"
				fileName="${var:chuteLogDir}/chute-status/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 格口日志目标：chute-ZhiQian-Tcp（智嵌设备 TCP 通信日志）。
		     注意：maxArchiveDays 不支持 NLog Layout 渲染，故固定为 7；
		     如需修改保留天数，请直接调整此值。 -->
		<target name="chute-ZhiQian-Tcp" xsi:type="File"
				fileName="${var:chuteLogDir}/chute-ZhiQian-Tcp/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 格口日志目标：chute-fault（格口异常与告警日志）。
		     注意：maxArchiveDays 不支持 NLog Layout 渲染，故固定为 7；
		     如需修改保留天数，请直接调整此值。 -->
		<target name="chute-fault" xsi:type="File"
				fileName="${var:chuteLogDir}/chute-fault/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 编排日志目标：sorting-orchestration（分拣编排步骤与业务编排事件）。 -->
		<target name="sorting-orchestration" xsi:type="File"
				fileName="${var:orchestrationLogDir}/sorting-orchestration/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 小车日志目标：carrier-status（载具上环/建环/状态变更等运营日志）。 -->
		<target name="carrier-status" xsi:type="File"
				fileName="${var:carrierLogDir}/carrier-status/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- EMC 日志目标：emc-Leadshaine（雷赛 EMC 控制器、IoPanel、传感器、信号塔通信日志）。 -->
		<target name="emc-Leadshaine" xsi:type="File"
				fileName="${var:emcLogDir}/emc-Leadshaine/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- EMC 故障日志目标：emc-fault（EMC 域 Warning+ 告警与异常聚合）。 -->
		<target name="emc-fault" xsi:type="File"
				fileName="${var:emcLogDir}/emc-fault/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- 系统日志目标：system-status（系统状态、IO 联动、信号塔、日志清理等系统管理服务日志）。 -->
		<target name="system-status" xsi:type="File"
				fileName="${var:systemLogDir}/system-status/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<target name="app-all" xsi:type="File"
				fileName="${basedir}/logs/application/${shortdate}.log"
				archiveEvery="Day"
				maxArchiveDays="7"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
	</targets>

	<rules>
		<!-- 控制台输出（摘要）：默认仅输出 Warning+ 与关键状态/PID 信息，避免 Modbus 重试刷屏。 -->
		<logger name="*" minlevel="Warning" writeTo="console" />
		<logger name="*"
		        minlevel="${configsetting:item=LoopTrack\:Logging\:ConsoleMinLevel:default=Information}"
		        maxlevel="Info"
		        writeTo="console">
			<filters defaultAction="Ignore">
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-status') or contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-pid')" action="Log" />
				<when condition="contains('${message}', 'LoopTrack状态') or contains('${message}', 'LoopTrack实时速度') or contains('${message}', 'HIL状态') or contains('${message}', 'HIL连接状态变化') or contains('${message}', 'HIL运行状态变化') or contains('${message}', 'HIL稳速状态变化')" action="Log" />
			</filters>
		</logger>

		<logger name="*"
		        minlevel="Debug"
		        maxlevel="Debug"
		        writeTo="console">
			<filters defaultAction="Ignore">
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-pid') and not contains('${message}', 'HIL调参')" action="Log" />
				<when condition="contains('${message}', 'LoopTrack调参')" action="Log" />
			</filters>
		</logger>

		<!-- status 分类：默认 Information 起记，记录运行状态与阶段性过程。 -->
		<logger name="*"
				final="false"
				minlevel="Information"
				writeTo="looptrack-status">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-status')" action="Log" />
			</filters>
		</logger>

		<!-- pid 分类：默认 Debug 起记，保留 PID 调参细节用于闭环诊断。 -->
		<logger name="*"
				final="false"
				minlevel="Debug"
				writeTo="looptrack-pid">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-pid') and not contains('${message}', 'HIL调参')" action="Log" />
				<when condition="contains('${message}', 'LoopTrack调速日志') and not contains('${message}', 'HIL调参')" action="Log" />
			</filters>
		</logger>
		<!-- speed 分类：实时速度与调速日志统一落盘，便于一站式复盘。 -->
		<logger name="*"
		        final="false"
		        minlevel="Information"
		        writeTo="looptrack-speed">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="equals('${logger}', 'looptrack-speed')" action="Log" />
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-speed')" action="Log" />
				<when condition="contains('${message}', 'LoopTrack实时速度日志')" action="Log" />
				<when condition="contains('${message}', 'HIL实时速度日志') or contains('${message}', 'HIL调速日志') or contains('${message}', 'LoopTrack调速日志')" action="Log" />
			</filters>
		</logger>
		<!-- modbus 分类：默认 Information 起记，聚焦链路与通信相关日志。 -->
		<logger name="LeiMaModbusClientAdapter"
				final="false"
				minlevel="Information"
				writeTo="looptrack-modbus">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${message}', 'Modbus')" action="Log" />
			</filters>
		</logger>

		<logger name="LeiMaLoopTrackManager"
				final="false"
				minlevel="Information"
				writeTo="looptrack-modbus">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${message}', 'Modbus')" action="Log" />
			</filters>
		</logger>

		<!-- fault 分类（事件名）：默认 Warning 起记，聚焦告警/异常类事件。 -->
		<logger name="*"
				final="false"
				minlevel="Warning"
				writeTo="looptrack-fault">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-fault')" action="Log" />
			</filters>
		</logger>

		<!-- fault 分类（消息关键词）：默认 Warning 起记，兜底捕获失败/告警/异常消息。 -->
		<logger name="LeiMaModbusClientAdapter"
		        final="false"
		        minlevel="Warning"
		        writeTo="looptrack-fault">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${message}', '失败') or contains('${message}', '告警') or contains('${message}', '异常')" action="Log" />
			</filters>
		</logger>

		<logger name="LeiMaLoopTrackManager"
		        final="false"
		        minlevel="Warning"
		        writeTo="looptrack-fault">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="contains('${message}', '失败') or contains('${message}', '告警') or contains('${message}', '异常')" action="Log" />
			</filters>
		</logger>

		<!-- chute-status：捕获 ZhiQianChuteManager 的 Information+ 状态日志
		     （连接状态变更、强排更新、锁格操作、目标格口变更等运营类信息）。 -->
		<logger name="ZhiQianChuteManager"
				final="false"
				minlevel="Information"
				writeTo="chute-status">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=Chutes\:ZhiQian\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- chute-ZhiQian-Tcp：捕获 ZhiQianBinaryClientAdapter 的 Information+ 通信日志
		     （TCP 连接、指令收发、重试明细等通信类信息）。 -->
		<logger name="ZhiQianBinaryClientAdapter"
				final="false"
				minlevel="Information"
				writeTo="chute-ZhiQian-Tcp">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=Chutes\:ZhiQian\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- chute-fault（管理器侧）：捕获 ZhiQianChuteManager 的 Warning+ 日志
		     （连接失败、写 DO 失败、轮询异常等告警/异常类信息）。
		     注意：此规则与 chute-status 规则共用同一 logger 名称，但级别不同（Information vs Warning）。 -->
		<logger name="ZhiQianChuteManager"
				final="false"
				minlevel="Warning"
				writeTo="chute-fault">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=Chutes\:ZhiQian\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- chute-fault（适配器侧）：捕获 ZhiQianBinaryClientAdapter 的 Warning+ 日志
		     （TCP 通信失败、指令收发失败、重试超限、释放异常等告警/异常类信息）。 -->
		<logger name="ZhiQianBinaryClientAdapter"
				final="false"
				minlevel="Warning"
				writeTo="chute-fault">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=Chutes\:ZhiQian\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Ignore" />
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- sorting-orchestration：捕获分拣编排服务日志并单独落盘。 -->
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.SortingTaskOrchestrationService"
		        final="false"
		        minlevel="Information"
		        writeTo="sorting-orchestration">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.SortingTaskCarrierLoadingService"
		        final="false"
		        minlevel="Information"
		        writeTo="sorting-orchestration">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.SortingTaskDropOrchestrationService"
		        final="false"
		        minlevel="Information"
		        writeTo="sorting-orchestration">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.ChuteDropSimulationHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="sorting-orchestration">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- carrier-status：捕获小车管理器与建环服务的 Information+ 日志（载具上环、建环流程、状态变更）。 -->
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.Carrier.InfraredSensorCarrierManager"
		        final="false"
		        minlevel="Information"
		        writeTo="carrier-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.CarrierLoopGroupingHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="carrier-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- emc-Leadshaine（状态侧）：捕获雷赛 EMC 控制器、IoPanel、传感器、信号塔的 Information+ 通信与状态日志。 -->
		<logger name="LeadshaineEmcController"
		        final="false"
		        minlevel="Information"
		        writeTo="emc-Leadshaine">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Emc.LeadshaineIoPanel"
		        final="false"
		        minlevel="Information"
		        writeTo="emc-Leadshaine">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Sensor.LeadshaineSensorManager"
		        final="false"
		        minlevel="Information"
		        writeTo="emc-Leadshaine">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.SignalTower.EmcSignalTower"
		        final="false"
		        minlevel="Information"
		        writeTo="emc-Leadshaine">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- emc-fault：捕获雷赛 EMC 域所有组件的 Warning+ 告警与异常日志。 -->
		<logger name="LeadshaineEmcController"
		        final="false"
		        minlevel="Warning"
		        writeTo="emc-fault">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Emc.LeadshaineIoPanel"
		        final="false"
		        minlevel="Warning"
		        writeTo="emc-fault">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Sensor.LeadshaineSensorManager"
		        final="false"
		        minlevel="Warning"
		        writeTo="emc-fault">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.SignalTower.EmcSignalTower"
		        final="false"
		        minlevel="Warning"
		        writeTo="emc-fault">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- system-status：捕获系统管理类服务的 Information+ 日志（系统状态变更、IO 联动、信号塔、日志清理等）。 -->
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.State.LocalSystemStateManager"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoMonitoringHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoLinkageHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoPanelStateTransitionHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.SignalTowerHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.LogCleanupHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>
		<logger name="Zeye.NarrowBeltSorter.Execution.Services.ChuteSelfHandlingHostedService"
		        final="false"
		        minlevel="Information"
		        writeTo="system-status">
			<filters defaultAction="Ignore">
				<when condition="true" action="Log" />
			</filters>
		</logger>

		<!-- 分类文件关闭时的兜底落盘：确保业务日志仍写入 app-all。
		     说明：LeiMa 设备日志复用 LoopTrack:Logging 配置段控制分类开关。 -->
		<logger name="LeiMa*"
		        final="false"
		        minlevel="Debug"
		        writeTo="app-all">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=LoopTrack\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Log" />
			</filters>
		</logger>

		<logger name="ZhiQian*"
		        final="false"
		        minlevel="Debug"
		        writeTo="app-all">
			<filters defaultAction="Ignore">
				<when condition="equals('${configsetting:item=Chutes\:ZhiQian\:Logging\:EnableCategoryFile:default=true}', 'false')" action="Log" />
			</filters>
		</logger>

		<!-- 兜底落盘：确保所有分类之外的业务日志同样落盘到 application 目录。 -->
		<logger name="*"
				final="false"
				minlevel="Debug"
				writeTo="app-all">
			<filters defaultAction="Log">
				<when condition="starts-with('${logger}', 'Microsoft.')" action="Ignore" />
				<when condition="starts-with('${logger}', 'System.')" action="Ignore" />
				<when condition="equals('${logger}', 'LeiMaModbusClientAdapter')" action="Ignore" />
				<when condition="equals('${logger}', 'LeiMaLoopTrackManager')" action="Ignore" />
				<when condition="equals('${logger}', 'ZhiQianBinaryClientAdapter')" action="Ignore" />
				<when condition="equals('${logger}', 'ZhiQianChuteManager')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.SortingTaskOrchestrationService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.SortingTaskCarrierLoadingService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.SortingTaskDropOrchestrationService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.ChuteDropSimulationHostedService')" action="Ignore" />
				<!-- 小车域：排除 carrier-status 已路由的日志，避免重复写入 app-all。 -->
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.Carrier.InfraredSensorCarrierManager')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.CarrierLoopGroupingHostedService')" action="Ignore" />
				<!-- EMC 域：排除 emc-Leadshaine/emc-fault 已路由的日志，避免重复写入 app-all。 -->
				<when condition="equals('${logger}', 'LeadshaineEmcController')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Emc.LeadshaineIoPanel')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.Sensor.LeadshaineSensorManager')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Drivers.Vendors.Leadshaine.SignalTower.EmcSignalTower')" action="Ignore" />
				<!-- 系统域：排除 system-status 已路由的日志，避免重复写入 app-all。 -->
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.State.LocalSystemStateManager')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoMonitoringHostedService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoLinkageHostedService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.Hosted.IoPanelStateTransitionHostedService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.SignalTowerHostedService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.LogCleanupHostedService')" action="Ignore" />
				<when condition="equals('${logger}', 'Zeye.NarrowBeltSorter.Execution.Services.ChuteSelfHandlingHostedService')" action="Ignore" />
				<!-- 新增设备分类前缀时，需同步更新此过滤条件，避免分类日志重复写入 app-all。 -->
				<when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-') or contains('${event-properties:item=EventId_Name:whenEmpty=}', 'chute-')" action="Ignore" />
			</filters>
		</logger>
	</rules>
</nlog>
