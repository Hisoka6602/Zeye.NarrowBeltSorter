<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">
  <extensions>
    <add assembly="NLog.Extensions.Logging" />
  </extensions>

  <variable name="loopTrackLogDir" value="${configsetting:name=LoopTrack:Logging:CategoryLogDirectory:defaultValue=logs/looptrack}" />

  <targets async="true">
    <target name="console" xsi:type="Console"
            layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

    <target name="looptrack-status" xsi:type="File"
            fileName="${var:loopTrackLogDir}/looptrack-status/${shortdate}.log"
            archiveEvery="Day"
            maxArchiveDays="${configsetting:name=LoopTrack:Logging:CategoryRetentionDays:defaultValue=7}"
            layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

    <target name="looptrack-pid" xsi:type="File"
            fileName="${var:loopTrackLogDir}/looptrack-pid/${shortdate}.log"
            archiveEvery="Day"
            maxArchiveDays="${configsetting:name=LoopTrack:Logging:CategoryRetentionDays:defaultValue=7}"
            layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />

    <target name="looptrack-modbus" xsi:type="File"
            fileName="${var:loopTrackLogDir}/looptrack-modbus/${shortdate}.log"
            archiveEvery="Day"
            maxArchiveDays="${configsetting:name=LoopTrack:Logging:CategoryRetentionDays:defaultValue=7}"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

    <target name="looptrack-fault" xsi:type="File"
            fileName="${var:loopTrackLogDir}/looptrack-fault/${shortdate}.log"
            archiveEvery="Day"
            maxArchiveDays="${configsetting:name=LoopTrack:Logging:CategoryRetentionDays:defaultValue=7}"
            layout="${longdate}|${level:uppercase=true}|${event-properties:item=EventId_Name:whenEmpty=${logger}}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Trace" writeTo="console" />

    <logger name="*"
            final="false"
            enabled="${configsetting:name=LoopTrack:Logging:EnableCategoryFile:defaultValue=true}"
            minlevel="Information"
            writeTo="looptrack-status">
      <filters defaultAction="Ignore">
        <when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-status')" action="Log" />
      </filters>
    </logger>

    <logger name="*"
            final="false"
            enabled="${configsetting:name=LoopTrack:Logging:EnableCategoryFile:defaultValue=true}"
            minlevel="Debug"
            writeTo="looptrack-pid">
      <filters defaultAction="Ignore">
        <when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-pid')" action="Log" />
      </filters>
    </logger>

    <logger name="LeiMaModbusClientAdapter,LeiMaLoopTrackManager"
            final="false"
            enabled="${configsetting:name=LoopTrack:Logging:EnableCategoryFile:defaultValue=true}"
            minlevel="Information"
            writeTo="looptrack-modbus">
      <filters defaultAction="Ignore">
        <when condition="contains('${message}', 'Modbus')" action="Log" />
      </filters>
    </logger>

    <logger name="*"
            final="false"
            enabled="${configsetting:name=LoopTrack:Logging:EnableCategoryFile:defaultValue=true}"
            minlevel="Warning"
            writeTo="looptrack-fault">
      <filters defaultAction="Ignore">
        <when condition="contains('${event-properties:item=EventId_Name:whenEmpty=}', 'looptrack-fault')" action="Log" />
      </filters>
    </logger>

    <logger name="LeiMaModbusClientAdapter,LeiMaLoopTrackManager"
            final="false"
            enabled="${configsetting:name=LoopTrack:Logging:EnableCategoryFile:defaultValue=true}"
            minlevel="Warning"
            writeTo="looptrack-fault">
      <filters defaultAction="Ignore">
        <when condition="contains('${message}', '失败') or contains('${message}', '告警') or contains('${message}', '异常')" action="Log" />
      </filters>
    </logger>
  </rules>
</nlog>
