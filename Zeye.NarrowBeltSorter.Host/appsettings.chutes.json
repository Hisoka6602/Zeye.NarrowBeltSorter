{
  // 文件作用：格口与小车能力配置文件（生产环境基线）。
  // 影响功能：影响 Chutes/Carrier 业务编排与偏移计算。
  // 使用场景：全环境统一格口参数基线；无环境覆盖文件。
  // 格口管理器默认配置（全局默认值）：控制智嵌 32 路继电器格口驱动。
  "Chutes": {
    // 是否启用格口管理（取值：true/false）。
    "Enabled": true,
    // 格口厂商标识（枚举全集：ZhiQian）。
    "Vendor": "ZhiQian",
    // 智嵌格口驱动配置（开发环境示例）。
    "ZhiQian": {
      // 是否启用智嵌格口驱动（取值：true/false）。
      "Enabled": true,
      // 单次命令超时（单位：毫秒，建议范围：100~5000）。
      "CommandTimeoutMs": 300,
      // 重试次数（不含首次，建议范围：0~5）。
      "RetryCount": 2,
      // 重试间隔（单位：毫秒，建议范围：10~1000）。
      "RetryDelayMs": 50,
      // 单模块指令绝对间隔（单位：毫秒，建议范围：0~1000；0 表示不额外等待）。
      "CommandAbsoluteIntervalMs": 20,
      // 状态轮询周期（单位：毫秒，建议范围：50~5000）。
      "PollIntervalMs": 1000,
      // 默认开闸时长（单位：毫秒，建议范围：20~5000）。
      "DefaultOpenDurationMs": 120,
      // 强排互斥开闸（true=仅允许单格口强排，false=允许并发强排）。
      "ForceOpenExclusive": true,
      // 设备配置拆分至 appsettings.devices.chutes.json / appsettings.{Environment}.devices.chutes.json。
      "Devices": [],
      // 格口分类日志配置：控制独立文件输出目录与保留周期。
      "Logging": {
        // 是否启用格口分类文件日志（取值：true/false）。
        "EnableCategoryFile": true,
        // 格口分类日志目录（相对或绝对路径）。
        "CategoryLogDirectory": "logs/chutes",
        // 格口分类日志保留天数（单位：天，建议范围：1~365）。
        "CategoryRetentionDays": 7
      }
    },
    // 格口强排后台服务配置。支持轮转（ChuteSequence 非空时生效）与固定（FixedChuteId 有值时生效）两种互斥模式。
    "ForcedRotation": {
      // 是否启用格口强排后台服务（取值：true/false）。
      "Enabled": true,
      // 强排切换间隔（单位：秒，建议范围：1~3600；默认 10 秒）。仅轮转模式下有效。
      "SwitchIntervalSeconds": 3,
      // 固定强排格口 Id（ChuteSequence 为空时生效；null 表示不启用固定模式；系统 Running 时闭合，非运行时自动断开）。
      "FixedChuteId": 102,
      // 强排轮转数组已拆分至 appsettings.devices.chutes.json / appsettings.{Environment}.devices.chutes.json。
      "ChuteSequence": []
    },
    // 包裹落格模拟后台服务配置（系统 Running 时自动给新包裹分配目标格口）。
    "DropSimulation": {
      // 是否启用包裹落格模拟后台服务（取值：true/false）。
      "Enabled": true,
      // 分配模式（枚举全集：Fixed、RoundRobin；Fixed=固定格口，RoundRobin=按数组轮询）。
      "Mode": "RoundRobin",
      // 固定分配格口 Id（Mode=Fixed 时生效）。
      "FixedChuteId": 101,
      // 包裹创建后延迟分配时间（单位：毫秒，建议范围：0~60000）。
      "AssignDelayMs": 200,
      // 轮询数组已拆分至 appsettings.devices.chutes.json / appsettings.{Environment}.devices.chutes.json。
      "ChuteSequence": []
    }
  },
  // 小车管理配置：用于红外感应器模式的建环与偏移计算。
  // 热更新说明：本节配置支持热更新，更新后由 CarrierManager 相关读取逻辑实时生效。
  "Carrier": {
    // 上车点相对感应位小车偏移（可为负数，建议范围：-200~200；支持热更新）。
    "LoadingZoneCarrierOffset": 8,
    // 格口相对感应位小车偏移映射（键：格口Id，值：偏移小车数，建议范围：-200~200；支持热更新）。
    "ChuteCarrierOffsetMap": {
      "132": 14,
      "131": 14,
      "130": 14,
      "129": 14
    }
  }
}
