{
  // 文件作用：Development 环轨设备参数文件。
  // 影响功能：影响开发环境串口/从站等设备连接参数。
  // 使用场景：开发环境 LoopTrack 设备参数覆盖。
  // 环线配置。
  "LoopTrack": {
    // 雷玛连接配置。
    "LeiMaConnection": {
      // Modbus 串口 RTU 配置。
      "SerialRtu": {
        // 串口号（示例：COM1；不支持热更新，涉及串口连接参数）。
        "PortName": "COM4",
        // 串口波特率。
        "BaudRate": 38400,
        // 串口校验位（枚举全集：None、Odd、Even、Mark、Space）。
        "Parity": "None",
        // 串口数据位。
        "DataBits": 8,
        // 串口停止位（枚举全集：None、One、Two、OnePointFive）。
        "StopBits": "One"
      }
    }
  }
}
