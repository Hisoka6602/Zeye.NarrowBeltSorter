{
  // 文件作用：Development 环轨设备参数覆盖文件。
  // 影响功能：覆盖开发/测试环境的串口或网关设备连接参数（串口号等硬件地址因环境而异）。
  // 使用场景：开发/测试机器的具体硬件参数；生产环境使用 appsettings.devices.looptrack.json 中的参数。
  // 环线配置。
  "LoopTrack": {
    // 雷玛连接配置。
    "LeiMaConnection": {
      // Modbus 串口 RTU 配置。
      "SerialRtu": {
        // 串口号（示例：COM1；不支持热更新，涉及串口连接参数）。
        "PortName": "COM4",
        // 串口波特率。
        "BaudRate": 38400,
        // 串口校验位（枚举全集：None、Odd、Even、Mark、Space）。
        "Parity": "None",
        // 串口数据位。
        "DataBits": 8,
        // 串口停止位（枚举全集：None、One、Two、OnePointFive）。
        "StopBits": "One"
      }
    }
  }
}
